# Task Ledger Backend — environment template
# Copy to .env locally. Never commit real secrets.

NODE_ENV=development
PORT=5000

# Required
SESSION_SECRET=

# Database — local PostgreSQL or AWS RDS
# Local:
DATABASE_URL=postgresql://admin:ks1234@127.0.0.1:5433/taskledger?sslmode=disable
# AWS RDS (Mumbai):
# DATABASE_URL=postgresql://tl_admin:YOUR_PASSWORD@task-ledger-db.xxxxx.ap-south-1.rds.amazonaws.com:5432/taskledger?sslmode=require

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173

# App
APP_BASE_URL=http://localhost:5000
SINGLE_TENANT_MODE=false
ALLOW_PUBLIC_REGISTRATION=true

# Storage — S3 (document uploads)
S3_DOCUMENT_BUCKET=documents
AWS_REGION=ap-south-1
# AWS credentials (use IAM roles in production, or set these for local dev)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Email — Resend (production)
EMAIL_PROVIDER=resend
RESEND_API_KEY=

# SMTP relay (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM_EMAIL=taskledger@ksanindustries.com
SMTP_FROM_NAME=Task Ledger

# Cookie security
COOKIE_SECURE=false
