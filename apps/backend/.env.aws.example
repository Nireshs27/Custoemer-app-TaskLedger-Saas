# Task Ledger Backend — AWS production deployment
# Copy to /opt/task-ledger/.env on EC2/ECS. Never commit real secrets.

NODE_ENV=production
PORT=3000

# AWS RDS PostgreSQL (Mumbai region)
DATABASE_URL=postgresql://tl_admin:YOUR_PASSWORD@task-ledger-db.xxxxx.ap-south-1.rds.amazonaws.com:5432/taskledger?sslmode=require

# Session & app
SESSION_SECRET=generate-a-random-64-char-secret
APP_BASE_URL=https://app.taskledger.com
FRONTEND_URL=https://app.taskledger.com
COOKIE_SECURE=true
SINGLE_TENANT_MODE=false
ALLOW_PUBLIC_REGISTRATION=true

# Storage — S3 (document uploads)
S3_DOCUMENT_BUCKET=task-ledger-documents
AWS_REGION=ap-south-1

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=
SMTP_FROM_EMAIL=taskledger@ksanindustries.com
SMTP_FROM_NAME=Task Ledger

# Optional: auto-push schema on first boot
SCHEMA_AUTO_PUSH=true
